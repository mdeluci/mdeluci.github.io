{% if site.enable_math %}
  {% unless page.pseudocode %}
    <script type="text/javascript">
      window.MathJax = {
        tex: { tags: 'ams' }
      };
    </script>
    <script
      defer
      id="MathJax-script"
      src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"
      crossorigin="anonymous">
    </script>
  {% endunless %}
{% endif %}

